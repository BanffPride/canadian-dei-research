    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
        color: #e2e8f0;
        min-height: 100vh;
        padding: 20px;
    }

    .container {
        max-width: 1400px;
        margin: 0 auto;
    }

    header {
        text-align: center;
        margin-bottom: 40px;
        animation: fadeIn 0.6s ease-in;
    }

    h1 {
        font-size: 2.5em;
        margin-bottom: 10px;
        background: linear-gradient(120deg, #60a5fa, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 700;
    }

    .subtitle {
        font-size: 1.1em;
        color: #cbd5e1;
        margin-bottom: 30px;
    }

    .nav-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        justify-content: center;
        animation: slideDown 0.6s ease-out;
    }

    .nav-tabs button {
        padding: 12px 24px;
        background: rgba(51, 65, 85, 0.5);
        border: 2px solid #64748b;
        color: #e2e8f0;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.95em;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .nav-tabs button:hover {
        background: rgba(99, 102, 241, 0.3);
        border-color: #6366f1;
        color: #60a5fa;
        transform: translateY(-2px);
    }

    .nav-tabs button.active {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border-color: #8b5cf6;
        color: white;
        box-shadow: 0 8px 16px rgba(99, 102, 241, 0.3);
    }

    .tab-content {
        display: none;
        animation: fadeIn 0.5s ease-in;
    }

    .tab-content.active {
        display: block;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
        gap: 30px;
        margin-bottom: 30px;
    }

    .chart-card {
        background: rgba(30, 41, 59, 0.8);
        border: 1px solid rgba(99, 102, 241, 0.3);
        border-radius: 12px;
        padding: 25px;
        backdrop-filter: blur(10px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }

    .chart-card:hover {
        background: rgba(30, 41, 59, 0.95);
        border-color: rgba(99, 102, 241, 0.6);
        box-shadow: 0 12px 48px rgba(99, 102, 241, 0.2);
        transform: translateY(-4px);
    }

    .chart-card h3 {
        font-size: 1.3em;
        margin-bottom: 20px;
        color: #60a5fa;
        font-weight: 600;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-box {
        background: rgba(99, 102, 241, 0.1);
        border-left: 4px solid #6366f1;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .stat-box:hover {
        background: rgba(99, 102, 241, 0.2);
        transform: translateY(-2px);
    }

    .stat-number {
        font-size: 2.2em;
        font-weight: 700;
        color: #60a5fa;
        margin-bottom: 5px;
    }

    .stat-label {
        font-size: 0.9em;
        color: #cbd5e1;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .full-width {
        grid-column: 1 / -1;
    }

    .insights {
        background: rgba(30, 41, 59, 0.8);
        border: 1px solid rgba(34, 197, 94, 0.3);
        border-left: 4px solid #22c55e;
        border-radius: 12px;
        padding: 25px;
        margin-top: 30px;
        backdrop-filter: blur(10px);
    }

    .insights h3 {
        color: #22c55e;
        margin-bottom: 15px;
        font-size: 1.2em;
    }

    .insights ul {
        list-style: none;
        padding: 0;
    }

    .insights li {
        padding: 10px 0;
        padding-left: 25px;
        position: relative;
        color: #cbd5e1;
        line-height: 1.6;
    }

    .insights li:before {
        content: "→";
        position: absolute;
        left: 0;
        color: #22c55e;
        font-weight: bold;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    canvas {
        max-height: 300px;
    }

    footer {
        text-align: center;
        margin-top: 50px;
        padding-top: 30px;
        border-top: 1px solid rgba(99, 102, 241, 0.2);
        color: #94a3b8;
        font-size: 0.9em;
    }

    @media (max-width: 768px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        h1 {
            font-size: 1.8em;
        }

        .nav-tabs {
            gap: 5px;
        }

        .nav-tabs button {
            padding: 10px 16px;
            font-size: 0.85em;
        }
    }
</style>
